{
  "name": "nubra-dashboard",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "start": "concurrently -n \"server,vite\" -c \"cyan,green\" \"node --experimental-strip-types server/index.ts\" \"vite --port 8000\"",
    "dev": "vite --port 8000",
    "build": "tsc -b && vite build",
    "server": "node --experimental-strip-types server/index.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "better-sqlite3": "^12.11.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "fastify": "^5.3.2",
    "lightweight-charts": "^5.0.0",
    "protobufjs": "^8.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-window": "^1.8.10",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.14",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-window": "^1.8.8",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "daisyui": "^4.12.24",
    "playwright": "^1.61.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
